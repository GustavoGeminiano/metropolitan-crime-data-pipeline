# -*- coding: utf-8 -*-
"""
Optimized Pipeline to Consolidate, Filter, and Aggregate Crime Data.

Executes an end-to-end data engineering workflow:
1. Converts multiple Excel files into a single intermediate CSV with standardized column names.
2. Filters the consolidated CSV based on domain-specific criteria (cities, years, etc.).
3. Groups and aggregates data to calculate incident counts per location and crime type.
4. Exports a formatted final report in Excel for business intelligence and reporting.
"""

import pandas as pd
import time
import os
import concurrent.futures
from typing import Dict, List
from tqdm import tqdm

# ==============================================================================
# CONFIGURATION SECTION
# ==============================================================================

# Input and output file paths
RAW_EXCEL_FILES = [
    "SPDadosCriminais_2022.xlsx", 
    "SPDadosCriminais_2023.xlsx", 
    "SPDadosCriminais_2024.xlsx", 
    "SPDadosCriminais_2025.xlsx"
]
FINAL_EXCEL_REPORT = "Aggregated_Crime_Report.xlsx"
INTERMEDIATE_CSV_FILE = "temp_full_data.csv"

# Column name mapping for standardization
# Key: Original column name in raw file | Value: Standardized column name in script
COLUMN_MAPPING: Dict[str, str] = {
    "NATUREZA_APURADA": "crime_nature", 
    "CIDADE": "city",
    "ANO_ESTATISTICA": "year", 
    "MES_ESTATISTICA": "month", 
    "BAIRRO": "neighborhood",
    "NOME_DELEGACIA": "police_station", 
    "RUBRICA": "legal_article", 
    "LATITUDE": "latitude", 
    "LONGITUDE": "longitude"
}

# Filtering criteria. Leave empty list to disable a filter (e.g., "year": [])
FILTERS: Dict[str, List] = {
    "year": [2022, 2023, 2024, 2025],
    "city": [
        "SANTOS", "CUBATÃO", "PRAIA GRANDE", "SÃO VICENTE", 
        "GUARUJÁ", "BERTIOGA", "MONGAGUÁ", "ITANHAÉM", "PERUÍBE"
    ],
}

# Columns defining the report aggregation level
GROUPING_COLUMNS: List[str] = [
    "crime_nature", "city", "neighborhood", "legal_article", "police_station",
    "month", "year", "latitude", "longitude"
]

# Dictionary mapping for cleaning city name variations
CITY_MAP: Dict[str, str] = {
    'S.VICENTE': 'SÃO VICENTE', 
    'S VICENTE': 'SÃO VICENTE',
    'P. GRANDE': 'PRAIA GRANDE', 
    'PRAIAGRANDE': 'PRAIA GRANDE',
    'CUBATAO': 'CUBATÃO'
}

# ==============================================================================
# PIPELINE FUNCTIONS
# ==============================================================================

def _process_file(file_path: str) -> pd.DataFrame:
    """
    Reads a single Excel file and its sheets. Executed in parallel for optimization.
    Standardizes municipality column names across different layout versions.
    """
    try:
        sheets = pd.read_excel(file_path, engine='openpyxl', sheet_name=None)
        df = pd.concat(sheets.values(), ignore_index=True) if sheets else pd.DataFrame()

        # Normalize municipality column name across varying legacy formats
        if 'NOME_MUNICIPIO' in df.columns:
            df.rename(columns={'NOME_MUNICIPIO': 'CIDADE'}, inplace=True)
        
        return df
    except FileNotFoundError:
        tqdm.write(f"WARNING: File '{file_path}' was not found.")
        return pd.DataFrame()
    except Exception as e:
        tqdm.write(f"ERROR: Could not process '{file_path}'. Details: {e}")
        return pd.DataFrame()

def convert_excel_to_csv(excel_paths: List[str], csv_path: str):
    """
    Orchestrates parallel ingestion of multiple Excel files, consolidates data,
    standardizes column names, and exports an intermediate CSV.
    """
    print(f"Creating intermediate CSV file from {len(excel_paths)} file(s)...")
    start_time = time.time()
    
    with concurrent.futures.ProcessPoolExecutor() as executor:
        results = list(tqdm(
            executor.map(_process_file, excel_paths), 
            total=len(excel_paths), 
            desc="Consolidating Excel Files"
        ))
    
    valid_dfs = [df for df in results if not df.empty]
    if not valid_dfs:
        print("No valid Excel files were processed. Aborting process.")
        return
    
    consolidated_df = pd.concat(valid_dfs, ignore_index=True)
    
    # Centralized column renaming before CSV export
    consolidated_df.rename(columns=COLUMN_MAPPING, inplace=True)
    consolidated_df.to_csv(csv_path, index=False, encoding='utf-8-sig')
    
    end_time = time.time()
    print(f"CSV consolidation completed in {round(end_time - start_time, 2)} seconds.")

def filter_csv(csv_path: str) -> pd.DataFrame:
    """
    Loads intermediate CSV and applies cleaning, data type casting, and filtering rules.
    """
    print(f"Starting filtering process on file '{csv_path}'...")
    start_time = time.time()
    
    # Load required columns to optimize memory usage
    required_cols = list(COLUMN_MAPPING.values())
    df = pd.read_csv(
        csv_path, usecols=required_cols,
        encoding='utf-8-sig', low_memory=False
    )
    
    # Type conversion and data cleaning
    df['year'] = pd.to_numeric(df['year'], errors='coerce')
    df.dropna(subset=['year'], inplace=True)
    df['year'] = df['year'].astype(int)
    
    df['city'] = df['city'].astype(str).str.strip().str.upper().replace(CITY_MAP)
    
    df['latitude'] = pd.to_numeric(df['latitude'], errors='coerce')
    df['longitude'] = pd.to_numeric(df['longitude'], errors='coerce')

    for col in ["crime_nature", "neighborhood", "legal_article", "police_station", "month"]:
        if col in df.columns:
            df[col] = df[col].astype(str).str.strip()

    # Apply configuration filters
    if FILTERS["year"]:
        df = df[df['year'].isin(FILTERS["year"])]
    if FILTERS["city"]:
        df = df[df['city'].isin(FILTERS["city"])]
    
    end_time = time.time()
    print(f"Filtering and cleaning completed in {round(end_time - start_time, 2)} seconds.")
    
    if df.empty:
        print("WARNING: No data remained after applying filters.")
    
    return df

def aggregate_data(df: pd.DataFrame) -> pd.DataFrame:
    """
    Groups filtered DataFrame by target dimensions and calculates total incident counts.
    """
    print("Starting data aggregation...")
    if df.empty:
        return df

    aggregated_df = df.groupby(GROUPING_COLUMNS, observed=False).size().to_frame('Quantity').reset_index()
    
    print("Aggregation completed.")
    return aggregated_df

def format_final_excel(df_final: pd.DataFrame, excel_path: str):
    """
    Exports aggregated DataFrame to Excel with custom formatting (auto-fit column width & freeze panes).
    """
    if df_final.empty:
        print("WARNING: No data available to generate final Excel report.")
        return

    print(f"Formatting final Excel report with {len(df_final)} rows...")
    with pd.ExcelWriter(excel_path, engine='openpyxl') as writer:
        df_final.to_excel(writer, sheet_name="Aggregated Report", index=False)
        worksheet = writer.sheets["Aggregated Report"]
        
        # Auto-adjust column width
        for column_cells in worksheet.columns:
            max_length = max(len(str(cell.value)) for cell in column_cells if cell.value)
            worksheet.column_dimensions[column_cells[0].column_letter].width = max_length + 2
        
        # Freeze top header row and enable auto-filters
        worksheet.freeze_panes = 'A2'
        worksheet.auto_filter.ref = worksheet.dimensions
    
    print(f"Excel report successfully saved to: '{excel_path}'")

# ==============================================================================
# MAIN EXECUTION BLOCK
# ==============================================================================
if __name__ == "__main__":
    total_start_time = time.time()
    
    # Step 1: Create intermediate CSV if it does not exist; otherwise, reuse existing file.
    if not os.path.exists(INTERMEDIATE_CSV_FILE):
        convert_excel_to_csv(RAW_EXCEL_FILES, INTERMEDIATE_CSV_FILE)
    else:
        print(f"Reusing existing intermediate CSV file: '{INTERMEDIATE_CSV_FILE}'.")

    # Step 2: Load and filter data.
    filtered_df = filter_csv(INTERMEDIATE_CSV_FILE)
    
    # Step 3: Aggregate data.
    aggregated_df = aggregate_data(filtered_df)
    
    # Step 4: Format and export final report.
    format_final_excel(aggregated_df, FINAL_EXCEL_REPORT)
    
    print("-" * 50)
    print("PIPELINE EXECUTED SUCCESSFULLY!")
    total_end_time = time.time()
    print(f"Total execution time: {round(total_end_time - total_start_time, 2)} seconds.")
